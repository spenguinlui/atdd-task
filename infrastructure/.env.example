# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C...

# Database
POSTGRES_PASSWORD=atdd
DATABASE_URL=postgresql://atdd:atdd@db:5432/atdd

# API Authentication (leave empty for development / no auth)
API_KEY=

# Which org does this deployment serve?
# personal = 00000000-0000-0000-0000-000000000001
# company  = 00000000-0000-0000-0000-000000000002
ATDD_ORG=00000000-0000-0000-0000-000000000001

# Link to remote dashboard (shown in nav for cross-environment access)
# Local sets this to server URL; Server leaves empty
REMOTE_DASHBOARD_URL=

# atdd-hub local path (on EC2)
ATDD_HUB_PATH=/opt/atdd-hub

# Claude CLI auth: run `claude login` inside the container
# Session is persisted in the bot-sessions volume
