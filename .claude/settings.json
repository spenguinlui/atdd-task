{
  "env": {
    "KANBAN_BACKEND": "jira"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "ask": [
      "Bash(bundle install:*)",
      "Bash(bundle update:*)",
      "Bash(gem install:*)",
      "Bash(npm install:*)",
      "Bash(npm update:*)",
      "Bash(yarn add:*)",
      "Bash(yarn install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm install:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(brew install:*)",
      "Bash(brew upgrade:*)"
    ],
    "deny": [
      "Write(./domains/**)",
      "Edit(./domains/**)",
      "Write(./requirements/**)",
      "Edit(./requirements/**)",
      "Write(./specs/**)",
      "Edit(./specs/**)",
      "Write(./knowledge/access/**)",
      "Edit(./knowledge/access/**)",
      "Edit(**/Gemfile)",
      "Edit(**/package.json)",
      "Edit(**/requirements.txt)",
      "Edit(**/Dockerfile)",
      "Edit(**/docker-compose.yml)",
      "Edit(./.github/workflows/**)",
      "Edit(**/.ruby-version)",
      "Edit(**/.node-version)",
      "Edit(**/.python-version)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guard-skill-invoke.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-agent-call.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-deliverables.sh"
          }
        ]
      },
      {
        "matcher": "mcp__atdd__atdd_task_update",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/enforce-e2e-decision.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/confidence-gate.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-e2e-mode.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-spec-format.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/workflow-router.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-review-persisted.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/record-metrics.sh"
          }
        ]
      }
    ]
  }
}
